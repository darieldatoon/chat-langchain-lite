# Copy this file to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=chat-lc-lite
LANGSMITH_WORKSPACE_ID=your-demo-workspace-id

DEMO_PRESENTER="robert"

# LangSmith Deployment (LangGraph Platform)
# When set, the Streamlit UI (app.py) calls the deployed agent via the
# langgraph SDK instead of running the agent in-process. Leave unset for
# fully-local development (the UI falls back to the in-process agent).
# In production this is the deployment's API URL; the UI authenticates to it
# with LANGSMITH_API_KEY.
LANGGRAPH_DEPLOYMENT_URL=
# Graph id from langgraph.json ("agent"). Rarely needs changing.
LANGGRAPH_ASSISTANT_ID=agent