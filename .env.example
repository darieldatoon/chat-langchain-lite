# Copy this file to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_WORKSPACE_ID=your-demo-workspace-id
LANGSMITH_TRACING=true

# DEMO_PRESENTER is the main knob: every demo resource is named
# chat-langchain-lite-<presenter> (project, dataset, prompts, Context Hub, …).
DEMO_PRESENTER="robert"

# Tracing project for agent runs. Set it to chat-langchain-lite-<DEMO_PRESENTER>
# so local/script traces land in the same project the setup scripts provision
# evaluators on. (A deployment otherwise traces to a project named after the
# deployment unless this var is set in the deployment env.)
LANGSMITH_PROJECT=chat-langchain-lite-robert

# FastHTML frontend (optional)
# Base URL the frontend uses to reach the co-located graph over the LangGraph
# SDK. Must be loopback. Defaults to the `langgraph dev` port; set to
# http://localhost:8000 in a deployment (the container's API port).
# LANGGRAPH_API_URL=http://localhost:2024
# Secret used to sign the session cookie that holds the chat thread id.
# SESSION_SECRET=change-me-in-production